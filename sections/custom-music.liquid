<div class="content-section" id="music">
    <div>
        <h1>{{ section.settings.section_title | default: 'MUSIC' }}</h1>
    </div>

    <div style="width: 100%; max-width: 800px; display: flex; justify-content: center;">
        {% if section.settings.spotify_embed != blank %}
            {{ section.settings.spotify_embed }}
        {% else %}
            <div class="placeholder-box" style="width: 100%; height: 352px; background-color: #111;">SPOTIFY WEB PLAYER</div>
        {% endif %}
    </div>
    
    <div class="carousel-container">
        <img src="{{ 'arrow-left.svg' | asset_url }}" alt="Previous Album" class="nav-arrow">
        
        <div class="bar">
            {% if section.settings.album_image != blank %}
                <img src="{{ section.settings.album_image | image_url: width: 600 }}" alt="{{ section.settings.album_title }}">
            {% else %}
                <img src="{{ 'album.jpg' | asset_url }}" alt="Music Section Image">
            {% endif %}
            
            <section>
                <h2>{{ section.settings.album_title | default: 'Seth' }}</h2>
                <a href="{{ section.settings.stream_link | default: '#' }}" target="_blank" style="text-decoration: none; color: inherit;">
                    <h2 id="stream-button">Stream</h2>
                </a>
            </section>
        </div>
        
        <img src="{{ 'arrow-right.svg' | asset_url }}" alt="Next Album" class="nav-arrow">
    </div>
</div>

{% schema %}
{
  "name": "Custom Music",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "MUSIC"
    },
    {
      "type": "textarea",
      "id": "spotify_embed",
      "label": "Spotify Embed Code (iframe)",
      "info": "Paste the iframe code directly from Spotify here."
    },
    {
      "type": "image_picker",
      "id": "album_image",
      "label": "Featured Album Image"
    },
    {
      "type": "text",
      "id": "album_title",
      "label": "Album Title",
      "default": "Seth"
    },
    {
      "type": "url",
      "id": "stream_link",
      "label": "Stream Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Music",
      "category": "Music"
    }
  ]
}
{% endschema %}