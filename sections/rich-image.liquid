<style>
  .image-text-{{ section.id }}-wrapper {
    margin-top: {{ section.settings.margin-top }}px;
    margin-bottom: {{ section.settings.margin-bottom }}px;
    text-align: center;
  }

  .image-text-{{ section.id }}-image {
    width: {{ section.settings.image-width }}px;
    max-width: 100%;
    margin-bottom: 1rem;
    border-radius: 4px;
  }

  .image-text-heading {
    margin-top: 0.5rem;
    margin-bottom: 0.7rem;

    {% if section.settings.font-size == 's' %}
      font-size: 16px;
    {% elsif section.settings.font-size == 'm' %}
      font-size: 24px;
    {% elsif section.settings.font-size == 'l' %}
      font-size: 32px;
    {% elsif section.settings.font-size == 'xl' %}
      font-size: 44px;
    {% endif %}
  }

  .image-text-description {
    line-height: 1.5rem;
  }

  @media screen and (max-width: 749px) {
    .image-text-heading {
      {% if section.settings.font-size == 's' %}
        font-size: 16px;
      {% elsif section.settings.font-size == 'm' %}
        font-size: 20px;
      {% elsif section.settings.font-size == 'l' %}
        font-size: 24px;
      {% elsif section.settings.font-size == 'xl' %}
        font-size: 28px;
      {% endif %}
    }
  }
</style>

<div class="page-width image-text-{{ section.id }}-wrapper">
  {% if section.settings.image != blank %}
    <img
      class="image-text-{{ section.id }}-image"
      src="{{ section.settings.image | image_url }}"
      alt="{{ section.settings.heading }}"
    >
  {% endif %}

  <h1 class="image-text-heading">{{ section.settings.heading }}</h1>
  <p class="image-text-description">{{ section.settings.text }}</p>
</div>

{% schema %}
{
  "name": "Image Above Text",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "number",
      "id": "image-width",
      "label": "Image width (px)",
      "default": 200
    },

    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "select",
      "id": "font-size",
      "label": "Heading size",
      "options": [
        { "label": "S", "value": "s" },
        { "label": "M", "value": "m" },
        { "label": "L", "value": "l" },
        { "label": "XL", "value": "xl" }
      ],
      "default": "m"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Description",
      "default": "Add some text here"
    },

    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "margin-top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "default": 20,
      "step": 1
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "default": 15,
      "step": 1
    }
  ],
  "presets": [
    {
      "name": "Image Above Text"
    }
  ]
}
{% endschema %}
