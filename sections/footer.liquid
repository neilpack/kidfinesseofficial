<style>
  .footer-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
    margin-top: 0.6rem;
  }
  .footer-nav a{
    font-size: {{ section.settings.nav_size_pc }}px;
  }

  .list-payment {
    {% if section.settings.payment-color == 'monochrome' %}
    filter: grayscale(1);
    {% elsif section.settings.payment-color == 'in-color' %}
    filter: inherit;
    {% endif %}
    list-style: none;
    display: flex;
    flex-direction: row;
    justify-content: center;
    padding-top: 20px;
  }
  li.list-payment__item {
    align-items: center;
    display: flex;
    padding: 0.5rem;
  }
  ul.list-unstyled.list-social {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
  }
  a.link.list-social__link {
    align-items: center;
    display: flex;
    padding: 0.6rem;
  }
  .list-social__link .icon {
    height: 1.6rem;
    width: 1.6rem;
  }
  .footer-info{
    display: flex;
    align-items: center;
    {% if section.settings.enable-social-icons %}
    justify-content: space-between;
    {% else %}
    justify-content: center;
    {% endif %}
  }
  .footer__big-logo{
    margin-top: 60px;
  }
  {% unless section.settings.enable_site_copyright %}
  .site-copy{
    width: 1px;
    height: 1px;
    opacity: 0;
    padding: 0;
    margin: 0 !important;
    overflow: hidden;
  }
  .copyright{
    padding-top: 0 !important;
  }
  {% endunless %}

  #shopify-section-footer{
    margin-top: {{ section.settings.margin-top }}px;
    margin-bottom: {{ section.settings.margin-bottom }}px;
  }
  
  @media screen and (max-width: 749px){
    .footer-nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 1rem;
      margin-top: 0.6rem;
    }
    .footer-nav a{
      font-size: {{ section.settings.nav_size_mobile }}px;
    }
    .footer-nav a:not(:last-child) {
      margin-bottom: 0.5rem;
    }
    .footer-info {
        flex-direction: column;
    }
    .footer__big-logo{
      margin-top: 30px;
    }
  }
  @media screen and (min-width: 750px){
    .footer-nav a:not(:last-child) {
      margin-right: 0.7rem;
    }
  }

  /* ------------------------------------------
     MOBILE FIXED SOCIALS CSS
  --------------------------------------------- */
  .mobile-fixed-socials {
    display: none; 
  }

  @media (max-width: 900px) {
    .mobile-fixed-socials {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      background-color: rgba(0, 0, 0, 0.95);
      border-top: 1px solid #333;
      padding: 1rem 0 0.5rem 0; /* Adjusted padding to fit the text */
      margin: 0;
      z-index: 1000;
      gap: 0.5rem; /* Space between icons row and text */
    }
    
    .mobile-social-icons-row {
      display: flex;
      justify-content: center;
      gap: 1.5rem; /* Spaced out nicely for thumbs */
    }

    .mobile-footer-text {
      color: #ffffff;
      font-size: 0.75rem;
      text-align: center;
      letter-spacing: 1px;
    }

    .mobile-footer-text a {
      color: #ffffff;
      text-decoration: none;
    }
    
    /* Push the original footer up slightly so it isn't hidden behind the fixed bar */
    #shopify-section-footer {
      padding-bottom: 90px !important;
    }
  }
</style>

<div class="page-width footer-info">
  <div class="footer-nav">
    {% if section.settings.footer_display == 'menu' %}
      {% for link in linklists[section.settings.footer_menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    {% elsif section.settings.footer_display == 'policies' %}
      <div class="policies footer-nav">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
                <a href="{{ policy.url }}">{{ policy.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {% endif %}
  </div>

  {% if section.settings.enable-social-icons %}
    {% render 'social-icons' %}
  {% endif %}
</div>

{% if section.settings.enable-payment-icons %}
  <div class="footer__payment">
    <ul class="list list-payment" role="list">
      {%- for type in shop.enabled_payment_types -%}
        <li class="list-payment__item">
          {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
        </li>
      {%- endfor -%}
    </ul>
  </div>
{% endif %}

<div class="copyright" style="text-align: center; margin-top: 20px;">
  <small style="margin: 9px 0;" class="copyright__content site-copy">
     <a href="/policies/privacy-policy" style="text-decoration: none; color: inherit;">Privacy Policy</a> &copy; {{ 'now' | date: '%Y' }}, KIDFINESSEOFFICIAL
  </small>
</div>

{% if section.settings.enable_big_logo %}
<div class="page-width footer__big-logo">
  <img style="width: 100%; vertical-align: top;" src="{% if section.settings.big_logo_img != blank %} {{ section.settings.big_logo_img | img_url: 'master' }} {% else %} {{ 'brandname.svg' | asset_url | image_url: 'master' }} {% endif %}">
</div>
{% endif %}

<div class="mobile-fixed-socials">
    <div class="mobile-social-icons-row">
        {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" target="_blank" aria-label="TikTok">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 20 20" style="width: 25px; height: auto;">
                    <path fill="#ffffff" d="M10.511 1.705h2.74s-.157 3.51 3.795 3.768v2.711s-2.114.129-3.796-1.158l.028 5.606A5.073 5.073 0 1 1 8.213 7.56h.708v2.785a2.298 2.298 0 1 0 1.618 2.205L10.51 1.705Z"/>
                </svg>
            </a>
        {%- endif -%}
        
        {%- if settings.social_twitch_link != blank -%}
            <a href="{{ settings.social_twitch_link }}" target="_blank" aria-label="Twitch">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" style="width: 25px; height: auto;">
                    <path fill="#ffffff" d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/>
                </svg>
            </a>
        {%- endif -%}

        {%- if settings.social_spotify_link != blank -%}
            <a href="{{ settings.social_spotify_link }}" target="_blank" aria-label="Spotify">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" style="width: 25px; height: auto;">
                    <path fill="#ffffff" d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.24 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.84.24 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.781s.18-1.2.78-1.381c4.26-1.32 11.28-1.02 15.72 1.621.539.3.719 1.02.419 1.56-.299.54-1.019.72-1.619.36z"/>
                </svg>
            </a>
        {%- endif -%}

        {%- if settings.social_apple_link != blank -%}
            <a href="{{ settings.social_apple_link }}" target="_blank" aria-label="Apple Music">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" style="width: 25px; height: auto;">
                    <path fill="#ffffff" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm3.878 13.922c-.675.297-1.428.14-1.956-.37-.803-.778-.718-2.046.182-2.735 1.583-1.216 3.737-1.488 5.485-.68-.891 1.706-2.146 3.09-3.711 3.785zm1.53-4.526c-1.968-.908-4.464-.61-6.173.743-1.422 1.127-1.895 3.04-.972 4.673.543.959 1.486 1.554 2.585 1.613v.013c0 .121-.06.224-.165.258-2.095.666-4.47.16-6.105-1.341-2.043-1.874-2.456-4.908-.946-7.228 1.157-1.776 3.123-2.84 5.244-2.84 1.34 0 2.628.435 3.693 1.258.941.728 1.621 1.761 1.839 2.851z"/>
                </svg>
            </a>
        {%- endif -%}

        {%- if settings.social_youtube_link != blank -%}
            <a href="{{ settings.social_youtube_link }}" target="_blank" aria-label="YouTube">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 20 20" style="width: 25px; height: auto;">
                    <path fill="#ffffff" d="M18.16 5.87c.34 1.309.34 4.08.34 4.08s0 2.771-.34 4.08a2.125 2.125 0 0 1-1.53 1.53c-1.309.34-6.63.34-6.63.34s-5.321 0-6.63-.34a2.125 2.125 0 0 1-1.53-1.53c-.34-1.309-.34-4.08-.34-4.08s0-2.771.34-4.08a2.173 2.173 0 0 1 1.53-1.53C4.679 4 10 4 10 4s5.321 0 6.63.34a2.173 2.173 0 0 1 1.53 1.53ZM8.3 12.5l4.42-2.55L8.3 7.4v5.1Z"/>
                </svg>
            </a>
        {%- endif -%}

        {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" target="_blank" aria-label="Instagram">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 20 20" style="width: 25px; height: auto;">
                    <path fill="#ffffff" fill-rule="evenodd" d="M13.23 3.492c-.84-.037-1.096-.046-3.23-.046-2.144 0-2.39.01-3.238.055-.776.027-1.195.164-1.487.273a2.43 2.43 0 0 0-.912.593 2.486 2.486 0 0 0-.602.922c-.11.282-.238.702-.274 1.486-.046.84-.046 1.095-.046 3.23 0 2.134.01 2.39.046 3.229.004.51.097 1.016.274 1.495.145.365.319.639.602.913.282.282.538.456.92.602.474.176.974.268 1.479.273.848.046 1.103.046 3.238.046 2.134 0 2.39-.01 3.23-.046.784-.036 1.203-.164 1.486-.273.374-.146.648-.329.921-.602.283-.283.447-.548.602-.922.177-.476.27-.979.274-1.486.037-.84.046-1.095.046-3.23 0-2.134-.01-2.39-.055-3.229-.027-.784-.164-1.204-.274-1.495a2.43 2.43 0 0 0-.593-.913 2.604 2.604 0 0 0-.92-.602c-.284-.11-.703-.237-1.488-.273ZM6.697 2.05c.857-.036 1.131-.045 3.302-.045 1.1-.014 2.202.001 3.302.045.664.014 1.321.14 1.943.374a3.968 3.968 0 0 1 1.414.922c.41.397.728.88.93 1.414.23.622.354 1.279.365 1.942C18 7.56 18 7.824 18 10.005c0 2.17-.01 2.444-.046 3.292-.036.858-.173 1.442-.374 1.943-.2.53-.474.976-.92 1.423a3.896 3.896 0 0 1-1.415.922c-.51.191-1.095.337-1.943.374-.857.036-1.122.045-3.302.045-2.171 0-2.445-.009-3.302-.055-.849-.027-1.432-.164-1.943-.364a4.152 4.152 0 0 1-1.414-.922 4.128 4.128 0 0 1-.93-1.423c-.183-.51-.329-1.085-.365-1.943C2.009 12.45 2 12.167 2 10.004c0-2.161 0-2.435.055-3.302.027-.848.164-1.432.365-1.942a4.44 4.44 0 0 1 .92-1.414 4.18 4.18 0 0 1 1.415-.93c.51-.183 1.094-.33 1.943-.366Zm.427 4.806a4.105 4.105 0 1 1 5.805 5.805 4.105 4.105 0 0 1-5.805-5.805Zm1.882 5.371a2.668 2.668 0 1 0 2.042-4.93 2.668 2.668 0 0 0-2.042 4.93Zm5.922-5.942a.958.958 0 1 1-1.355-1.355.958.958 0 0 1 1.355 1.355Z" clip-rule="evenodd"/>
                </svg>
            </a>
        {%- endif -%}
    </div>
    <div class="mobile-footer-text">
        <a href="/policies/privacy-policy">Privacy Policy</a> &copy; {{ 'now' | date: '%Y' }}, KIDFINESSEOFFICIAL
    </div>
</div>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "footer_display",
      "label": "Display menu or policies",
      "info": "To set up policy pages, go to settings => Policies",
      "options": [
        {
          "value": "menu",
          "label": "Menu"
        },
        {
          "value": "policies",
          "label": "Policy Pages"
        }
      ],
      "default": "menu"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu"
    },
    {
      "type": "range",
      "id": "nav_size_pc",
      "label": "Links size (PC view)",
      "min": 10,
      "max": 35,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "nav_size_mobile",
      "label": "Links size (Mobile view)",
      "min": 10,
      "max": 35,
      "step": 1,
      "default": 16
    },
    {
      "type": "header",
      "content": "Payment icons"
    },
    {
      "type": "checkbox",
      "id": "enable-payment-icons",
      "label": "Show payment icons",
      "default": false
    },
    {
      "type": "select",
      "id": "payment-color",
      "label": "Payment icons color",
      "options": [
        {
          "value": "in-color",
          "label": "In color"
        },
        {
          "value": "monochrome",
          "label": "Monochrome"
        }
      ],
      "default": "monochrome"
    },
    {
      "type": "header",
      "content": "Socials"
    },
    {
      "type": "checkbox",
      "id": "enable-social-icons",
      "label": "Show social icons",
      "info": "You can set them in Theme Settings => Socials",
      "default": true
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "checkbox",
      "id": "enable_site_copyright",
      "label": "Show store copyright",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_eyecey_copyright",
      "label": "Show EYECEY copyright",
      "info": "Thanks yall for the support <3",
      "default": false
    },
    {
      "type": "header",
      "content": "Big logo"
    },
    {
      "type": "checkbox",
      "id": "enable_big_logo",
      "label": "Show big logo",
      "info": "In this setting you can add your big logo",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "big_logo_img",
      "label": "Big logo",
      "info": "Before uploading make sure that it looks like this placeholder and in SVG format"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "margin-top",
      "label": "Top padding",
      "min": 0,
      "max": 70,
      "default": 30,
      "step": 1
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 70,
      "default": 15,
      "step": 1
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}