<style>
  .footer-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
    margin-top: 0.6rem;
  }
  .footer-nav a{
    font-size: {{ section.settings.nav_size_pc }}px;
  
  }

  .eyecey{
    margin: 5px 0 16px;
  }
  .list-payment {
    {% if section.settings.payment-color == 'monochrome' %}
    filter: grayscale(1);
    {% elsif section.settings.payment-color == 'in-color' %}
    filter: inherit;
    {% endif %}
    list-style: none;
    display: flex;
    flex-direction: row;
    justify-content: center;
    padding-top: 20px;
  }
  li.list-payment__item {
    align-items: center;
    display: flex;
    padding: 0.5rem;
  }
  ul.list-unstyled.list-social {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
  }
  a.link.list-social__link {
    align-items: center;
    display: flex;
    padding: 0.6rem;
  }
  .list-social__link .icon {
    height: 1.6rem;
    width: 1.6rem;
  }
  .footer-info{
    display: flex;
    align-items: center;
    {% if section.settings.enable-social-icons %}
    justify-content: space-between;
    {% else %}
    justify-content: center;
    {% endif %}
  }
  .footer__big-logo{
    margin-top: 60px;
  }
  {% unless section.settings.enable_site_copyright %}
  .site-copy{
    width: 1px;
    height: 1px;
    opacity: 0;
    padding: 0;
    margin: 0 !important;
    overflow: hidden;
  }
  .copyright{
    padding-top: 0 !important;
  }
  {% endunless %}

  {% unless section.settings.enable_eyecey_copyright %}
  .eyecey{
    width: 1px;
    height: 1px;
    opacity: 0;
    padding: 0;
    margin: 0;
    overflow: hidden;
  }
  {% endunless %}
  #shopify-section-footer{
    margin-top: {{ section.settings.margin-top }}px;
    margin-bottom: {{ section.settings.margin-bottom }}px;
  }
  @media screen and (max-width: 749px){
  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 1rem;
    margin-top: 0.6rem;
  }
  .footer-nav a{
  font-size: {{ section.settings.nav_size_mobile }}px;
  
  }
  .footer-nav a:not(:last-child) {
    margin-bottom: 0.5rem;
  }
    .footer-info {
      flex-direction: column;
  }
    .footer__big-logo{
      margin-top: 30px;
    }
  }
  @media screen and (min-width: 750px){
  .footer-nav a:not(:last-child) {
    margin-right: 0.7rem;
  }
  }
</style>
<div class="page-width footer-info">
  <div class="footer-nav">
    {% if section.settings.footer_display == 'menu' %}
      {% for link in linklists[section.settings.footer_menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    {% elsif section.settings.footer_display == 'policies' %}
      <div class="policies footer-nav">
              {%- for policy in shop.policies -%}
                {%- if policy != blank -%}
                      <a href="{{ policy.url }}">{{ policy.title }}</a>
                {%- endif -%}
              {%- endfor -%}
            </div>
    {% endif %}
  </div>

{% if section.settings.enable-social-icons %}
  {% render 'social-icons' %}
{% endif %}
</div>

{% if section.settings.enable-payment-icons %}
  <div class="footer__payment">
    <ul class="list list-payment" role="list">
      {%- for type in shop.enabled_payment_types -%}
        <li class="list-payment__item">
          {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
        </li>
      {%- endfor -%}
    </ul>
  </div>
{% endif %}

<div class="copyright">
  <small style="margin: 9px 0;" class="copyright__content site-copy"> &copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}</small>
  <small class="copyright__content eyecey">
     <a href="https://www.instagram.com/josephl.2023">site by yeonix </a> 
  </small>
</div>
{% if section.settings.enable_big_logo %}
<div class="page-width footer__big-logo">
  <img style="width: 100%; vertical-align: top;" src="{% if section.settings.big_logo_img != blank %} {{ section.settings.big_logo_img | img_url: 'master' }} {% else %} {{ 'brandname.svg' | asset_url | image_url: 'master' }} {% endif %}">
</div>
{% endif %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "footer_display",
      "label": "Display menu or policies",
      "info": "To set up policy pages, go to settings => Policies",
      "options": [
        {
          "value": "menu",
          "label": "Menu"
        },
        {
          "value": "policies",
          "label": "Policy Pages"
        }
      ],
      "default": "menu"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu"
    },
    {
      "type": "range",
      "id": "nav_size_pc",
      "label": "Links size (PC view)",
      "min": 10,
      "max": 35,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "nav_size_mobile",
      "label": "Links size (Mobile view)",
      "min": 10,
      "max": 35,
      "step": 1,
      "default": 16
    },
    {
      "type": "header",
      "content": "Payment icons"
    },
    {
      "type": "checkbox",
      "id": "enable-payment-icons",
      "label": "Show payment icons",
      "default": false
    },
    {
      "type": "select",
      "id": "payment-color",
      "label": "Payment icons color",
      "options": [
        {
          "value": "in-color",
          "label": "In color"
        },
        {
          "value": "monochrome",
          "label": "Monochrome"
        }
      ],
      "default": "monochrome"
    },
    {
      "type": "header",
      "content": "Socials"
    },
    {
      "type": "checkbox",
      "id": "enable-social-icons",
      "label": "Show social icons",
      "info": "You can set them in Theme Settings => Socials",
      "default": true
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "checkbox",
      "id": "enable_site_copyright",
      "label": "Show store copyright",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_eyecey_copyright",
      "label": "Show EYECEY copyright",
      "info": "Thanks yall for the support <3",
      "default": false
    },
    {
      "type": "header",
      "content": "Big logo"
    },
    {
      "type": "checkbox",
      "id": "enable_big_logo",
      "label": "Show big logo",
      "info": "In this setting you can add your big logo",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "big_logo_img",
      "label": "Big logo",
      "info": "Before uploading make sure that it looks like this placeholder and in SVG format"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "margin-top",
      "label": "Top padding",
      "min": 0,
      "max": 70,
      "default": 30,
      "step": 1
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 70,
      "default": 15,
      "step": 1
    }
  ]
}
{% endschema %}