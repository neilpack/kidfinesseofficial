<style>
  .nav-menu-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background: transparent;
    width: 100%;
  }

  .nav-menu {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: {{ section.settings.item_spacing }}px;
    margin: 0 auto;
  }

  .nav-menu a {
    color: {{ section.settings.text_color }} !important;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 600;
    font-size: {{ section.settings.font_size }}px;
    letter-spacing: 0.5px;
    transition: all 0.25s ease;
  }

  .nav-menu a:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .nav-menu {
      gap: {{ section.settings.item_spacing_mobile }}px;
    }

    .nav-menu-wrapper {
      padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px 0;
    }

    .nav-menu a {
      font-size: {{ section.settings.font_size_mobile }}px;
    }
  }
</style>

<div class="nav-menu-wrapper">
  {% if section.settings.menu != blank %}
    <nav class="nav-menu">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>
  {% else %}
    <p style="color: #fff;">Select a menu in the editor</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Centered Navigation Menu",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Select menu"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Menu text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (desktop)",
      "min": 10,
      "max": 40,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size (mobile)",
      "min": 10,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Spacing between items (desktop)",
      "min": 5,
      "max": 100,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "item_spacing_mobile",
      "label": "Spacing between items (mobile)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (desktop)",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (desktop)",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Centered Navigation Menu",
      "category": "Header"
    }
  ]
}
{% endschema %}
