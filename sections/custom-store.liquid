<style>
  /* Force white text and the global theme font on this specific section */
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} a {
    color: #ffffff !important;
    font-family: var(--font-heading-family) !important;
  }

  /* Spread the grid items further apart */
  #shopify-section-{{ section.id }} .store-grid {
    gap: 4rem !important; /* Increased from 2rem to spread them out */
  }

  /* Make the images a little smaller */
  #shopify-section-{{ section.id }} .placeholder-box {
    width: 200px !important; /* Shrunk from 250px */
    height: 200px !important; /* Shrunk from 250px */
  }

  /* Stream/Merch button specific styles */
  #shopify-section-{{ section.id }} #merch-button {
    border: 1px solid #ffffff;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 20px;
    display: inline-block;
    transition: all 0.3s ease;
  }
  
  #shopify-section-{{ section.id }} #merch-button:hover {
    cursor: pointer;
    background-color: #ffffff;
    color: #000000 !important; 
  }
</style>

<div class="content-section" id="store">
    <div>
        <h2>{{ section.settings.section_title | default: 'STORE' }}</h2>
    </div>
    
    <div class="store-grid">
        {% assign collection = collections[section.settings.collection_handle] %}
        
        {% if collection != blank and collection.products_count > 0 %}
            {% for product in collection.products limit: 3 %}
                <div style="display: flex; flex-direction: column; align-items: center; gap: 12px;">
                    <a href="{{ product.url }}" class="placeholder-box" style="text-decoration: none;">
                        <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title | escape }}">
                    </a>
                    
                    <p style="color: white; text-align: center; margin: 0; font-size: 1.1rem; text-transform: uppercase; line-height: 1.4;">
                        {{ product.title }}<br>
                        
                        {% if product.available %}
                            {{ product.price | money }}
                        {% else %}
                            <span style="text-decoration: line-through; opacity: 0.7;">{{ product.price | money }}</span><br>
                            <span style="color: #cccccc; font-size: 0.9rem; letter-spacing: 1px;">SOLD OUT</span>
                        {% endif %}
                    </p>
                </div>
            {% endfor %}
        {% else %}
            <div class="placeholder-box">MERCH 1</div>
            <div class="placeholder-box">MERCH 2</div>
            <div class="placeholder-box">MERCH 3</div>
        {% endif %}
    </div>

    <a href="{{ collection.url | default: '#store' }}" style="text-decoration: none; color: inherit;">
        <h2 id="merch-button">{{ section.settings.button_text | default: 'SEE ALL MERCH' }}</h2>
    </a>
</div>

{% schema %}
{
  "name": "Custom Store",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "STORE"
    },
    {
      "type": "collection",
      "id": "collection_handle",
      "label": "Select Merch Collection"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SEE ALL MERCH"
    }
  ],
  "presets": [
    {
      "name": "Custom Store",
      "category": "Store"
    }
  ]
}
{% endschema %}