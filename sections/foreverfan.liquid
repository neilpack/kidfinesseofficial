<style>
  /* Scoped styles using section.id to prevent global CSS conflicts */
  .foreverfan-wrapper-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1400px; /* Widened to allow room for two side-by-side embeds */
    margin: {{ section.settings.margin_top }}px auto {{ section.settings.margin_bottom }}px auto;
    padding: 0 20px;
    text-align: center;
  }

  .foreverfan-heading-{{ section.id }} {
    margin-bottom: 40px;
    font-size: 32px;
    text-transform: uppercase;
    font-family: var(--font-heading-family), sans-serif; 
  }

  /* The new row container holding both embeds */
  .foreverfan-flex-row-{{ section.id }} {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: flex-start;
    gap: 53px; /* Gap between the embeds*/
    width: 100%;
    flex-wrap: wrap; /* Ensures they stack on top of each other on mobile */
  }

  /* The container wrapping each individual iframe */
  .foreverfan-embed-container-{{ section.id }} {
    /* Calculates the container height AND width based on your zoom level so it doesn't leave blank space */
    height: calc({{ section.settings.iframe_height }}px * {{ section.settings.embed_scale | divided_by: 100.0 }});
    width: calc({{ section.settings.max_width }}px * {{ section.settings.embed_scale | divided_by: 100.0 }});
    max-width: 100%;
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  .foreverfan-embed-container-{{ section.id }} iframe {
    /* The iframe stays its original size for rendering, but scales down visually */
    width: {{ section.settings.max_width }}px; 
    height: {{ section.settings.iframe_height }}px;
    border: none;
    border-radius: 8px; 
    transform: scale({{ section.settings.embed_scale | divided_by: 100.0 }});
    transform-origin: top center;
  }

  /* Shrink the gap slightly on mobile phones so it looks natural */
  @media (max-width: 768px) {
    .foreverfan-flex-row-{{ section.id }} {
      gap: 40px; 
    }
  }
</style>

<div class="foreverfan-wrapper-{{ section.id }}" id="stayconnected">
  {% if section.settings.heading != blank %}
    <h2 class="foreverfan-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="foreverfan-flex-row-{{ section.id }}">
    
    {% if section.settings.embed_url != blank %}
      <div class="foreverfan-embed-container-{{ section.id }}">
        <iframe src="{{ section.settings.embed_url }}" title="Forever Fan Connect" allowfullscreen loading="lazy"></iframe>
      </div>
    {% endif %}

    {% if section.settings.embed_url_2 != blank %}
      <div class="foreverfan-embed-container-{{ section.id }}">
        <iframe src="{{ section.settings.embed_url_2 }}" title="Forever Fan Presave" allowfullscreen loading="lazy"></iframe>
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Forever Fan Embeds",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "STAY CONNECTED"
    },
    {
      "type": "text",
      "id": "embed_url",
      "label": "Left URL (Community)",
      "default": "https://fvr.fan/kid-finesse/kidfinessefamily"
    },
    {
      "type": "text",
      "id": "embed_url_2",
      "label": "Right URL (Presave)",
      "default": "https://fvr.fan/kid-finesse/presaveforever"
    },
    {
      "type": "header",
      "content": "Embed Sizing & Zoom (Applies to both)"
    },
    {
      "type": "range",
      "id": "embed_scale",
      "label": "Zoom / Scale Content (%)",
      "min": 25, 
      "max": 100,
      "step": 5,
      "default": 100,
      "info": "Shrinks the contents inside the embed. 100% is normal size."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Embed Internal Max Width (px)",
      "min": 300,
      "max": 1000,
      "step": 10,
      "default": 600
    },
    {
      "type": "range",
      "id": "iframe_height",
      "label": "Embed Internal Height (px)",
      "min": 300,
      "max": 1200,
      "step": 10,
      "default": 600
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Forever Fan Embeds",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}