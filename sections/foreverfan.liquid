<style>
  /* Scoped styles using section.id to prevent global CSS conflicts */
  .foreverfan-wrapper-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1200px;
    margin: {{ section.settings.margin_top }}px auto {{ section.settings.margin_bottom }}px auto;
    padding: 0 20px;
    text-align: center;
  }

  .foreverfan-heading-{{ section.id }} {
    margin-bottom: 24px;
    font-size: 32px;
    text-transform: uppercase;
    font-family: var(--font-heading-family), sans-serif; 
  }

  .foreverfan-embed-container-{{ section.id }} {
    width: 100%;
    display: flex;
    justify-content: center;
    /* This calculates the container height based on your zoom level so it doesn't leave blank space */
    height: calc({{ section.settings.iframe_height }}px * {{ section.settings.embed_scale | divided_by: 100.0 }});
    overflow: hidden;
  }

  .foreverfan-embed-container-{{ section.id }} iframe {
    width: 100%;
    max-width: {{ section.settings.max_width }}px; 
    height: {{ section.settings.iframe_height }}px;
    border: none;
    border-radius: 8px; 
    /* The CSS magic that shrinks the actual Forever Fan content */
    transform: scale({{ section.settings.embed_scale | divided_by: 100.0 }});
    transform-origin: top center;
  }
</style>

<div class="foreverfan-wrapper-{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="foreverfan-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="foreverfan-embed-container-{{ section.id }}">
    <iframe src="{{ section.settings.embed_url }}" title="Forever Fan Connect" allowfullscreen loading="lazy"></iframe>
  </div>
</div>

{% schema %}
{
  "name": "Forever Fan Embed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "STAY CONNECTED"
    },
    {
      "type": "text",
      "id": "embed_url",
      "label": "Forever Fan URL",
      "default": "https://fvr.fan/kid-finesse/kidfinessefamily"
    },
    {
      "type": "header",
      "content": "Embed Sizing & Zoom"
    },
    {
      "type": "range",
      "id": "embed_scale",
      "label": "Zoom / Scale Content (%)",
      "min": 25, 
      "max": 100,
      "step": 5,
      "default": 100,
      "info": "Shrinks the contents inside the embed. 100% is normal size."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Embed Max Width (px)",
      "min": 300,
      "max": 1000,
      "step": 10,
      "default": 600
    },
    {
      "type": "range",
      "id": "iframe_height",
      "label": "Embed Internal Height (px)",
      "min": 300,
      "max": 1200,
      "step": 10,
      "default": 600
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Forever Fan Embed",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}