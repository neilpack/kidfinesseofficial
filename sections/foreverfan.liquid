<style>
  /* Scoped styles using section.id to prevent global CSS conflicts */
  .foreverfan-wrapper-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1400px; /* Widened to allow room for side-by-side text and embed */
    margin: {{ section.settings.margin_top }}px auto {{ section.settings.margin_bottom }}px auto;
    padding: 0 20px;
    text-align: center;
    overflow: hidden; /* Prevents horizontal scrollbar during animations */
  }

  .foreverfan-heading-{{ section.id }} {
    margin-bottom: 40px;
    font-size: 32px;
    text-transform: uppercase;
    font-family: var(--font-heading-family), sans-serif; 
  }

  /* The main container stacking the two rows on top of each other */
  .foreverfan-stack-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 60px; /* Space between the top embed row and bottom embed row */
    width: 100%;
  }

  /* The row container holding one embed and one textbox */
  .foreverfan-embed-row-{{ section.id }} {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 40px; /* Gap between the text box and the embed */
    width: 100%;
  }

  /* The text box describing the embed */
  .foreverfan-text-box-{{ section.id }} {
    background-color: #000000;
    border: 1px solid #ffffff;
    color: #ffffff;
    /* Match height dynamically to 2/3 of the scaled iframe height */
    height: calc(({{ section.settings.iframe_height }}px * {{ section.settings.embed_scale | divided_by: 100.0 }}) * 0.6667);
    flex: 1;
    max-width: 600px; /* Wide width for the text box */
    padding: 40px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: left;
    box-sizing: border-box;
    overflow-y: auto;
  }

  .foreverfan-text-box-{{ section.id }} p {
    font-family: var(--font-body-family), sans-serif;
    font-size: 26px;
    line-height: 1.6;
    margin: 0;
    color: #ffffff !important;
  }

  /* The container wrapping each individual iframe */
  .foreverfan-embed-container-{{ section.id }} {
    /* Calculates the container height AND width based on your zoom level */
    height: calc({{ section.settings.iframe_height }}px * {{ section.settings.embed_scale | divided_by: 100.0 }});
    width: calc({{ section.settings.max_width }}px * {{ section.settings.embed_scale | divided_by: 100.0 }});
    max-width: 100%;
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  .foreverfan-embed-container-{{ section.id }} iframe {
    /* The iframe stays its original size for rendering, but scales down visually */
    width: {{ section.settings.max_width }}px; 
    height: {{ section.settings.iframe_height }}px;
    border: none;
    border-radius: 8px; 
    transform: scale({{ section.settings.embed_scale | divided_by: 100.0 }});
    transform-origin: top center;
  }

  /* =========================================
     ANIMATION STYLES (Desktop Only)
  ========================================= */
  @media (min-width: 769px) {
    /* Top row elements (Starts left, swoops right) */
    .foreverfan-hidden-left-{{ section.id }} {
      opacity: 0;
      filter: blur(5px);
      transform: translateX(-100%);
      transition: all 1s ease-out;
    }
    
    /* Bottom row elements (Starts right, swoops left) */
    .foreverfan-hidden-right-{{ section.id }} {
      opacity: 0;
      filter: blur(5px);
      transform: translateX(100%);
      transition: all 1s ease-out;
    }

    .foreverfan-show-{{ section.id }} {
      opacity: 1;
      filter: blur(0);
      transform: translateX(0);
    }

    /* Stagger items inside rows from Left to Right */
    .foreverfan-embed-row-{{ section.id }} > :nth-child(1) {
      transition-delay: 0ms;
    }
    .foreverfan-embed-row-{{ section.id }} > :nth-child(2) {
      transition-delay: 200ms;
    }
  }

  @media (prefers-reduced-motion) {
    .foreverfan-hidden-left-{{ section.id }},
    .foreverfan-hidden-right-{{ section.id }} {
      transition: none;
    }
  }

  /* Mobile Styles: Hide the text boxes and reduce gaps */
  @media (max-width: 768px) {
    .foreverfan-text-box-{{ section.id }} {
      display: none !important; 
    }
    .foreverfan-stack-{{ section.id }} {
      gap: 40px; 
    }
    .foreverfan-embed-row-{{ section.id }} {
      flex-direction: column;
    }
  }
</style>

<div class="foreverfan-wrapper-{{ section.id }}" id="stayconnected">
  {% if section.settings.heading != blank %}
    <h1 class="foreverfan-heading-{{ section.id }}">{{ section.settings.heading }}</h1>
  {% endif %}

  <div class="foreverfan-stack-{{ section.id }}">
    
    <!-- ROW 1: Text Box (Left) + Community Embed (Right) -->
    <!-- Applies left-to-right swoop -->
    {% if section.settings.embed_url != blank %}
      <div class="foreverfan-embed-row-{{ section.id }}">
        
        <!-- Text Box Left (Animates First: 0ms delay) -->
        {% if section.settings.community_text != blank %}
          <div class="foreverfan-text-box-{{ section.id }} foreverfan-hidden-left-{{ section.id }}">
            {{ section.settings.community_text }}
          </div>
        {% endif %}

        <!-- Embed Right (Animates Second: 200ms delay) -->
        <div class="foreverfan-embed-container-{{ section.id }} foreverfan-hidden-left-{{ section.id }}">
          <iframe src="{{ section.settings.embed_url }}" title="Forever Fan Connect" allowfullscreen loading="lazy"></iframe>
        </div>
      </div>
    {% endif %}

    <!-- ROW 2: Presave Embed (Left) + Text Box (Right) -->
    <!-- Applies right-to-left swoop -->
    {% if section.settings.embed_url_2 != blank %}
      <div class="foreverfan-embed-row-{{ section.id }}">
        
        <!-- Embed Left (Animates First: 0ms delay) -->
        <div class="foreverfan-embed-container-{{ section.id }} foreverfan-hidden-right-{{ section.id }}">
          <iframe src="{{ section.settings.embed_url_2 }}" title="Forever Fan Presave" allowfullscreen loading="lazy"></iframe>
        </div>

        <!-- Text Box Right (Animates Second: 200ms delay) -->
        {% if section.settings.presave_text != blank %}
          <div class="foreverfan-text-box-{{ section.id }} foreverfan-hidden-right-{{ section.id }}">
            {{ section.settings.presave_text }}
          </div>
        {% endif %}

      </div>
    {% endif %}

  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Only run the observer if the screen width is greater than mobile sizing
    if (window.innerWidth > 768) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('foreverfan-show-{{ section.id }}');
          } else {
            // Re-hide element when scrolling out of view so it animates again
            entry.target.classList.remove('foreverfan-show-{{ section.id }}');
          }
        });
      }, { threshold: 0.1 });

      // Grab both left-sliding and right-sliding elements
      const hiddenLeft = document.querySelectorAll('.foreverfan-hidden-left-{{ section.id }}');
      const hiddenRight = document.querySelectorAll('.foreverfan-hidden-right-{{ section.id }}');

      hiddenLeft.forEach((el) => observer.observe(el));
      hiddenRight.forEach((el) => observer.observe(el));
    }
  });
</script>

{% schema %}
{
  "name": "Forever Fan Embeds",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "STAY CONNECTED"
    },
    {
      "type": "header",
      "content": "Top Embed (Community)"
    },
    {
      "type": "text",
      "id": "embed_url",
      "label": "Community Embed URL",
      "default": "https://fvr.fan/kid-finesse/kidfinessefamily"
    },
    {
      "type": "richtext",
      "id": "community_text",
      "label": "Community Description Box (Left)",
      "default": "<p>Join the Kid Finesse family. Sign up to get exclusive updates, early access to tickets, and behind-the-scenes content directly to your phone!</p>"
    },
    {
      "type": "header",
      "content": "Bottom Embed (Presave)"
    },
    {
      "type": "text",
      "id": "embed_url_2",
      "label": "Presave Embed URL",
      "default": "https://fvr.fan/kid-finesse/presaveforever"
    },
    {
      "type": "richtext",
      "id": "presave_text",
      "label": "Presave Description Box (Right)",
      "default": "<p>Pre-save the upcoming tracks to be the first to hear them the moment they drop. Don't miss out on all of Kid Finesse's new releases.</p>"
    },
    {
      "type": "header",
      "content": "Embed Sizing & Zoom (Applies to both)"
    },
    {
      "type": "range",
      "id": "embed_scale",
      "label": "Zoom / Scale Content (%)",
      "min": 25, 
      "max": 100,
      "step": 5,
      "default": 100,
      "info": "Shrinks the contents inside the embed. 100% is normal size."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Embed Internal Max Width (px)",
      "min": 300,
      "max": 1000,
      "step": 10,
      "default": 600
    },
    {
      "type": "range",
      "id": "iframe_height",
      "label": "Embed Internal Height (px)",
      "min": 300,
      "max": 1200,
      "step": 10,
      "default": 600
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Forever Fan Embeds",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}