<style>
  /* 1. Force Titles to be White and use your New York Font */
  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2 {
    color: #ffffff !important;
    font-family: var(--font-heading-family) !important;
  }

  /* 2. Force Labels and standard text to be white */
  #shopify-section-{{ section.id }} label,
  #shopify-section-{{ section.id }} p {
    color: #cccccc !important; /* Slightly off-white so it doesn't clash with the title */
  }

  /* 3. Make the Input Boxes Pop against the black background */
  #shopify-section-{{ section.id }} input,
  #shopify-section-{{ section.id }} textarea,
  #shopify-section-{{ section.id }} .field__input {
    background-color: #1a1a1a !important; /* Dark grey so it stands out */
    color: #ffffff !important; /* Bright white text when someone is typing */
    border: 1px solid #555555 !important; /* Clean visible border */
    border-radius: 4px !important;
    box-shadow: none !important;
  }

  /* 4. Add a cool highlight effect when someone clicks inside a box */
  #shopify-section-{{ section.id }} input:focus,
  #shopify-section-{{ section.id }} textarea:focus,
  #shopify-section-{{ section.id }} .field__input:focus {
    border: 1px solid #ffffff !important; /* Border turns bright white */
    background-color: #000000 !important; /* Background fades to black */
    outline: none !important;
  }

  /* 5. Style the Submit Button so it demands attention */
  #shopify-section-{{ section.id }} button,
  #shopify-section-{{ section.id }} .button,
  #shopify-section-{{ section.id }} .contact__button .button {
    background-color: #ffffff !important;
    color: #000000 !important;
    border: 1px solid #ffffff !important;
    border-radius: 4px !important;
    font-size: 18px !important;
    font-family: var(--font-heading-family) !important;
    text-transform: uppercase !important;
    transition: all 0.3s ease !important;
    cursor: pointer;
  }

  /* 6. Button Hover Effect */
  #shopify-section-{{ section.id }} button:hover,
  #shopify-section-{{ section.id }} .button:hover,
  #shopify-section-{{ section.id }} .contact__button .button:hover {
    background-color: #000000 !important;
    color: #ffffff !important;
  }
</style>