<header class="bar">
    <a href="{{ routes.root_url }}">
        <img src="{{ 'KF_NEW.png' | asset_url }}" alt="{{ shop.name }} Logo" class="logo">
    </a>
    
    <nav>
        <ul class="bar">
            <li class="dropdown-parent">
                <a href="#music">MUSIC</a>
                <ul class="dropdown-menu">
                    <li><a href="#top-songs">TOP SONGS</a></li>
                    <li><a href="#presave">PRESAVE</a></li>
                </ul>
            </li>
            
            <li class="dropdown-parent">
                <a href="{{ routes.all_products_collection_url }}">SHOP</a>
                <ul class="dropdown-menu">
                    <li><a href="/collections/clothing">CLOTHING</a></li>
                    <li><a href="/collections/vinyls">VINYLs</a></li>
                </ul>
            </li>
            
            <li class="dropdown-parent">
                <a href="#connected">STAY CONNECTED</a>
                <ul class="dropdown-menu">
                    <li><a href="{{ routes.account_url }}">ACCOUNT</a></li>
                </ul>
            </li>
        </ul>
    </nav>

    <div class="social-icons">
        <a href="https://www.tiktok.com/@kidfinesseofficial" target="_blank">
            <img src="{{ 'socials.png' | asset_url }}" alt="TikTok">
        </a>
        <a href="https://www.twitch.tv/kidfinesseofficial" target="_blank">
            <img src="{{ 'socials.png' | asset_url }}" alt="Twitch">
        </a>
        <a href="#UNKNOWN" target="_blank">
            <img src="{{ 'socials.png' | asset_url }}" alt="Spotify">
        </a>
        <a href="#UNKNOWN" target="_blank">
            <img src="{{ 'socials.png' | asset_url }}" alt="Apple Music">
        </a>
        <a href="https://www.youtube.com/channel/UC9Xo5n8s1Z5j3k5l6m7n8o9" target="_blank">
            <img src="{{ 'socials.png' | asset_url }}" alt="YouTube">
        </a>
        <a href="#UNKNOWN" target="_blank">
            <img src="{{ 'socials.png' | asset_url }}" alt="Soundcloud">
        </a>
        <a href="https://www.instagram.com/kidfinesseofficial/" target="_blank">
            <img src="{{ 'socials.png' | asset_url }}" alt="Instagram">
        </a>
    </div>
</header>

<main>
    <div>
        <picture>
            <source media="(max-width: 900px)" srcset="{{ 'hero_phone.png' | asset_url }}">
            <img src="{{ 'hero.png' | asset_url }}" alt="{{ shop.name }} Hero Image" class="hero-image">
        </picture>
    </div>

    <div class="content-section">
        <div>
            <h1>MUSIC</h1>
        </div>

        <div>
            <div class="placeholder-box">SPOTIFY WEB PLAYER</div>
        </div>
        
        <div class="carousel-container">
            <img src="{{ 'arrow-left.svg' | asset_url }}" alt="Previous Album" class="nav-arrow">
            
            <div class="bar">
                <img src="{{ 'album.jpg' | asset_url }}" alt="Music Section Image">
                <section>
                    <h2>Seth</h2>
                    <a href="https://open.spotify.com/album/3kkgnce07RxrDSPRy9covD" target="_blank" style="text-decoration: none; color: inherit;">
                        <h2 id="stream-button">Stream</h2>
                    </a>
                </section>
            </div>
            
            <img src="{{ 'arrow-right.svg' | asset_url }}" alt="Next Album" class="nav-arrow">
        </div>
    </div>

    <div class="content-section" id="store">
        <div>
            <h2>STORE</h2>
        </div>
        
        <div class="store-grid">
            <div class="placeholder-box">MERCH 1</div>
            <div class="placeholder-box">MERCH 2</div>
            <div class="placeholder-box">MERCH 3</div>
        </div>

        <a href="{{ routes.all_products_collection_url }}" style="text-decoration: none; color: inherit;">
            <h2 id="merch-button">SEE ALL MERCH</h2>
        </a>
    </div>
</main>