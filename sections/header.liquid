<header class="bar">
  <a href="{{ routes.root_url }}" style="text-decoration: none;">
    {%- if section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | img_url: '150x' }}" alt="{{ section.settings.logo.alt | default: shop.name }}" class="logo" width="{{ section.settings.logo.width }}" height="{{ section.settings.logo.height }}">
    {%- else -%}
      <img src="{{ 'KF_NEW.png' | asset_url }}" alt="KidFinesseOfficial Logo" class="logo" width="150" height="150">
    {%- endif -%}
  </a>

  <nav>
    <ul class="bar">
      {%- for link in linklists[section.settings.menu].links -%}
        <li>
          <a href="{{ link.url }}">{{ link.title | upcase }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>
  
