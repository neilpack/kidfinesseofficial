<style>
  header.bar {
    transition: background-color 0.3s ease, border-bottom 0.3s ease;
  }
  header.bar.scrolled {
    background-color: rgba(0, 0, 0, 0.95);
    border-bottom: 1px solid #333;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const header = document.querySelector('header.bar');
    
    // Ensure header exists on the page before trying to add events to it
    if (header) {
      window.addEventListener('scroll', () => {
        // If scrolled down more than 50 pixels, add the 'scrolled' class
        if (window.scrollY > 50) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      });
    }

    // Dropdown logic for mobile (from your original JS)
    const dropdownParents = document.querySelectorAll('.dropdown-parent');
    dropdownParents.forEach(parent => {
      parent.addEventListener('click', function(event) {
        if (window.innerWidth <= 768) {
          event.preventDefault(); 
          this.classList.toggle('mobile-open'); 
        }
      });
    });

    document.addEventListener('click', function(event) {
      if (window.innerWidth <= 768) {
        dropdownParents.forEach(parent => {
          if (!parent.contains(event.target)) {
            parent.classList.remove('mobile-open');
          }
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Navigation Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}